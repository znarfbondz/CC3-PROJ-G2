import tkinter as tk
import math

window = tk.Tk()
window.title("Math Toolkit GUI app")
window.configure(bg="#F4F7D7")
window.geometry("530x780")

label = tk.Label(window,
                 text="MATH APP",
                 font=("Arial", 20, "bold"),
                 fg="black",
                 bg="#F0D49E")


entry1 = tk.Entry(window,
                 width=20,
                 font=("Arial", 20),
                 fg="black",
                 bg="white")

entry2 = tk.Entry(window,
                 width=20,
                 font=("Arial", 20),
                 fg="black",
                 bg="white")

entry3 = tk.Entry(window,
                 width=20,
                 font=("Arial", 20),
                 fg="black",
                 bg="white")

result =tk.Label(window,
        text="Result Will Appear Here",
        font=("Arial", 15),
        fg="#691A17",
        bg="#FA8282")



def add():
    try:
      total = int(entry1.get()) + int(entry2.get()) + int(entry3.get())
      result.config(text="Result:" + str(total))
    except ValueError:
        result.config(text="Please Enter Valid Number")

def Largest():
    try:
      total = max(int(entry1.get()) , int(entry2.get()) , int(entry3.get()))
      result.config(text="Result:" + str(total))
    except ValueError:
      result.config(text="Please Enter Valid Number")

def Smallest():
    try:
       total = min(int(entry1.get()) , int(entry2.get()) , int(entry3.get()))
       result.config(text="Result:" + str(total))
    except ValueError:
       result.config(text="Please Enter Valid Number")

def Ave():
    try:
        total = int(entry1.get()) + int(entry2.get()) + int(entry3.get())
        average = total / 3
        result.config(text="Result:" + str(average))
    except ValueError:
        result.config(text="Please Enter Valid Number")
    except ZeroDivisionError:
        result.config(text="Number Can't Be Zero")

def Pow():
    try:
        total = pow(int(entry1.get()), int(entry2.get()))
        sagot = total + int(entry3.get())
        result.config(text="Result:" + str(sagot))
    except ValueError:
        result.config(text="Please Enter Valid Number")

def hehe():
    try:
        total = int(entry1.get()) + int(entry2.get())
        sagot = total / int(entry3.get())
        result.config(text="Result:" + str(sagot))
    except ValueError:
        result.config(text="Please Enter Valid Number")
    except ZeroDivisionError:
        result.config(text="Number Can't Be Zero")
def GCD():
    try:
        total = math.gcd(int(entry1.get()), int(entry2.get()), int(entry3.get()))
        result.config(text="Result:" + str(total))
    except ValueError:
        result.config(text="Please Enter Valid Number")
    except ZeroDivisionError:
        result.config(text="Number Can't Be Zero")

def LCM():
    try:
         total = math.lcm(int(entry1.get()), int(entry2.get()), int(entry3.get()))
         result.config(text="Result:" + str(total))
    except ValueError:
         result.config(text="Please Enter Valid Number")
    except ZeroDivisionError:
         result.config(text="Number Can't Be Zero")



button1 = tk.Button(window,
                   text="ADD",
                   font=(15),
                   width=30,
                   bg="#8DD996",
                   command=add)

button2 = tk.Button(window,
                   text="LARGEST NUMBER",
                   font=(15),
                   width=30,
                    bg="#8DD996",
                   command=Largest)

button3 = tk.Button(window,
                   text="SMALLEST NUMBER",
                   font=(15),
                   width=30,
                    bg="#8DD996",
                   command=Smallest)

button4 = tk.Button(window,
                   text="AVERAGE",
                   font=(15),
                   width=30,
                    bg="#8DD996",
                   command=Ave)

button5 = tk.Button(window,
                   text="PAWER + THIRD",
                   font=(15),
                   width=30,
                    bg="#8DD996",
                   command=Pow)

button6 = tk.Button(window,
                   text="(A + B) / C",
                   font=(15),
                   width=30,
                    bg="#8DD996",
                   command=hehe)

button7 = tk.Button(window,
                   text="COMPUTE GCD",
                   font=(15),
                   width=30,
                    bg="#8DD996",
                   command=GCD)

button8 = tk.Button(window,
                   text="COMPUTE LCM",
                   font=(15),
                   width=30,
                    bg="#8DD996",
                   command=LCM)


label.pack(pady=35)
entry1.pack(pady=10)
entry2.pack(pady=10)
entry3.pack(pady=10)
result.pack(pady=15)
button1.pack(pady=5, padx=30)
button2.pack(pady=5, padx=30)
button3.pack(pady=5, padx=30)
button4.pack(pady=5, padx=30)
button5.pack(pady=5, padx=30)
button6.pack(pady=5, padx=30)
button7.pack(pady=5, padx=30)
button8.pack(pady=5, padx=30)
window.mainloop()
